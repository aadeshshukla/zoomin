<?xml version="1.0" encoding="utf-8"?>
<!--
    Root layout: a full-screen ConstraintLayout that overlays a Permission
    Denial panel on top of the camera preview when the user has not yet
    (or has refused to) grant CAMERA permission.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Live camera preview. Fills the entire screen. -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Zoom indicator: top-right, semi-transparent. -->
    <TextView
        android:id="@+id/zoomLabel"
        style="@style/OverlayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="20dp"
        android:background="#80000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/zoom_label_format"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Zoom: 1.0x" />

    <!-- Hint: bottom-center, semi-transparent. -->
    <TextView
        android:id="@+id/hintLabel"
        style="@style/OverlayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="56dp"
        android:background="#80000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/hint_pinch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!--
        Permission denial panel. Visible only after the user has refused
        CAMERA — controlled programmatically by toggling `visibility`.
    -->
    <LinearLayout
        android:id="@+id/permissionPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/permission_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/permissionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/permission_required_title"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/permissionMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/permission_required_message"
            android:textColor="#FFDDDDDD"
            android:textSize="15sp" />

        <Button
            android:id="@+id/permissionRetryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/permission_retry" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
