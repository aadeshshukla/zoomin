<?xml version="1.0" encoding="utf-8"?>
<!--
    Empty data extraction ruleset. The app does not back up any user data,
    but AGP 8 + targetSdk 34 require this reference to exist.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="device" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="device" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
